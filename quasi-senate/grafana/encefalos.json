      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "ffeagtzfyvvnkf"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH\ndims AS (\n  SELECT\n    base_model,\n    provider,\n    COUNT(*) AS n,\n    AVG(CASE WHEN downstream_verdict IN ('approved','approve','success') THEN 1.0 ELSE 0.0 END) AS q1,\n    AVG(CASE WHEN json_parse_ok = true AND http_status = 200 THEN 1.0 ELSE 0.0 END) AS q2,\n    PERCENTILE_CONT(0.5) WITHIN GROUP (ORDER BY latency_ms) AS p50_ms,\n    AVG(CASE WHEN model_verified IS NOT NULL THEN\n          CASE WHEN model_verified = true THEN 1.0 ELSE 0.0 END\n        ELSE NULL END) AS q4_raw,\n    AVG(CASE WHEN retries = 0 AND pipeline_attempt = 1 THEN 1.0 ELSE 0.0 END) AS q5,\n    AVG(CASE WHEN role IN ('A3_gate','B2_reviewer') AND verdict_reasoning IS NOT NULL THEN\n          CASE WHEN downstream_verdict IN ('approved','approve','success') THEN 1.0 ELSE 0.5 END\n        ELSE NULL END) AS q6_raw,\n    AVG(CASE WHEN issue_number IS NOT NULL AND cycle_id IS NOT NULL THEN 1.0 ELSE 0.5 END) AS q7\n  FROM senate_telemetry\n  WHERE $__timeFilter(timestamp) AND dry_run = false\n    AND downstream_verdict IS NOT NULL\n  GROUP BY base_model, provider\n  HAVING COUNT(*) >= 3\n),\nlat_max AS (SELECT MAX(p50_ms) AS mx FROM dims),\nscored AS (\n  SELECT\n    d.base_model, d.provider, d.n,\n    d.q1                                                        AS q1,\n    d.q2                                                        AS q2,\n    GREATEST(0, 1.0 - d.p50_ms / NULLIF(lm.mx, 0))            AS q3,\n    COALESCE(d.q4_raw, 0.5)                                     AS q4,\n    d.q5                                                        AS q5,\n    COALESCE(d.q6_raw, d.q1)                                    AS q6,\n    d.q7                                                        AS q7,\n    CASE d.provider\n      WHEN 'groq'         THEN 0.8\n      WHEN 'cerebras'     THEN 0.7\n      WHEN 'fireworks'    THEN 0.9\n      WHEN 'huggingface'  THEN 0.6\n      WHEN 'hf'           THEN 0.6\n      WHEN 'swissai'      THEN 0.7\n      WHEN 'mistral'      THEN 1.1\n      WHEN 'native'       THEN 1.2\n      ELSE 1.0\n    END AS cost_f\n  FROM dims d CROSS JOIN lat_max lm\n)\nSELECT\n  base_model, provider, n,\n  ROUND(q1::numeric, 3)  AS q1_correctness,\n  ROUND(q2::numeric, 3)  AS q2_compliance,\n  ROUND(q3::numeric, 3)  AS q3_latency,\n  ROUND(q4::numeric, 3)  AS q4_fidelity,\n  ROUND(q5::numeric, 3)  AS q5_reliability,\n  ROUND(q6::numeric, 3)  AS q6_reasoning,\n  ROUND(q7::numeric, 3)  AS q7_traceability,\n  ROUND((0.35*q1 + 0.20*q2 + 0.10*q3 +\n         0.10*q4 + 0.10*q5 + 0.10*q6 + 0.05*q7)::numeric, 3) AS Q_composite,\n  ROUND(((0.35*q1 + 0.20*q2 + 0.10*q3 +\n          0.10*q4 + 0.10*q5 + 0.10*q6 + 0.05*q7) / cost_f)::numeric, 3) AS enc_score\nFROM scored\nSELECT base_model || ' (' || provider || ')' AS value FROM scored ORDER BY enc_score DESC LIMIT 1",
          "refId": "A"
        }
      ],
      "title": "\ud83c\udfc6 Best \u03f6 Model",
      "type": "stat"
    },
