{
  "__inputs": [
    {
      "name": "DS_POSTGRESQL",
      "label": "PostgreSQL",
      "description": "quasi_senate postgres datasource on Camelot",
      "type": "datasource",
      "pluginId": "postgres",
      "pluginName": "PostgreSQL"
    }
  ],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "10.0.0"
    },
    {
      "type": "datasource",
      "id": "postgres",
      "name": "PostgreSQL",
      "version": "1.0.0"
    }
  ],
  "annotations": { "list": [] },
  "description": "Rolling 7-day model performance: approval rate, JSON compliance, latency, provider fidelity — across all five Senate Loop roles.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "refresh": "5m",
  "schemaVersion": 37,
  "style": "dark",
  "tags": ["quasi", "senate", "models", "performance"],
  "templating": { "list": [] },
  "time": { "from": "now-7d", "to": "now" },
  "timepicker": {},
  "timezone": "utc",
  "title": "QUASI Pauli-Test \u2014 Model Performance",
  "uid": "quasi-model-performance",
  "version": 1,
  "panels": [

    {
      "collapsed": false,
      "id": 100,
      "title": "7-Day Overview",
      "type": "row",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 }
    },

    {
      "id": 1,
      "title": "LLM Calls (7 days)",
      "type": "stat",
      "gridPos": { "x": 0, "y": 1, "w": 4, "h": 5 },
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none"
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
          "rawSql": "SELECT count(*) AS \"LLM Calls\" FROM senate_telemetry WHERE timestamp > now() - interval '7 days' AND dry_run = false",
          "format": "table"
        }
      ]
    },

    {
      "id": 2,
      "title": "Active Models (7 days)",
      "type": "stat",
      "gridPos": { "x": 4, "y": 1, "w": 4, "h": 5 },
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none"
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
          "rawSql": "SELECT count(DISTINCT base_model) AS \"Models\" FROM senate_telemetry WHERE timestamp > now() - interval '7 days' AND dry_run = false",
          "format": "table"
        }
      ]
    },

    {
      "id": 3,
      "title": "Overall Approval Rate (7 days)",
      "type": "stat",
      "gridPos": { "x": 8, "y": 1, "w": 4, "h": 5 },
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 40 },
              { "color": "yellow", "value": 60 },
              { "color": "green", "value": 75 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none"
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
          "rawSql": "SELECT round(100.0 * sum(CASE WHEN downstream_verdict='approved' THEN 1 ELSE 0 END) / NULLIF(count(CASE WHEN downstream_verdict IN ('approved','rejected','json_fail') THEN 1 END), 0), 1) AS \"Approval %\" FROM senate_telemetry WHERE timestamp > now() - interval '7 days' AND dry_run = false",
          "format": "table"
        }
      ]
    },

    {
      "id": 4,
      "title": "JSON Compliance (7 days)",
      "type": "stat",
      "gridPos": { "x": 12, "y": 1, "w": 4, "h": 5 },
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 70 },
              { "color": "yellow", "value": 85 },
              { "color": "green", "value": 95 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none"
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
          "rawSql": "SELECT round(100.0 * sum(CASE WHEN json_parse_ok = true THEN 1 ELSE 0 END) / count(*), 1) AS \"JSON %\" FROM senate_telemetry WHERE timestamp > now() - interval '7 days' AND dry_run = false",
          "format": "table"
        }
      ]
    },

    {
      "id": 5,
      "title": "Avg Latency (7 days)",
      "type": "stat",
      "gridPos": { "x": 16, "y": 1, "w": 4, "h": 5 },
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "orange", "value": 30 },
              { "color": "red", "value": 60 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none"
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
          "rawSql": "SELECT round(avg(latency_ms) / 1000.0, 1) AS \"Avg Latency (s)\" FROM senate_telemetry WHERE timestamp > now() - interval '7 days' AND dry_run = false",
          "format": "table"
        }
      ]
    },

    {
      "id": 6,
      "title": "Provider Fidelity (7 days)",
      "type": "stat",
      "gridPos": { "x": 20, "y": 1, "w": 4, "h": 5 },
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 80 },
              { "color": "green", "value": 95 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none"
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
          "rawSql": "SELECT round(100.0 * sum(CASE WHEN model_verified = true THEN 1 ELSE 0 END) / NULLIF(count(CASE WHEN model_verified IS NOT NULL THEN 1 END), 0), 1) AS \"Fidelity %\" FROM senate_telemetry WHERE timestamp > now() - interval '7 days' AND dry_run = false",
          "format": "table"
        }
      ]
    },

    {
      "collapsed": false,
      "id": 101,
      "title": "Hall of Fame / Shame",
      "type": "row",
      "gridPos": { "x": 0, "y": 6, "w": 24, "h": 1 }
    },

    {
      "id": 10,
      "title": "\ud83d\udfe2 Top Performer (7 days, \u226510 calls)",
      "type": "stat",
      "gridPos": { "x": 0, "y": 7, "w": 8, "h": 6 },
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "green" },
          "mappings": []
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "value",
        "colorMode": "background",
        "graphMode": "none",
        "text": { "titleSize": 16, "valueSize": 28 }
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
          "rawSql": "SELECT base_model || ' \u2014 ' || coalesce(round(100.0 * sum(CASE WHEN downstream_verdict='approved' THEN 1 ELSE 0 END) / NULLIF(count(CASE WHEN downstream_verdict IN ('approved','rejected','json_fail') THEN 1 END),0),0)::text,'?') || '% approval' AS \"Best Model\" FROM senate_telemetry WHERE timestamp > now() - interval '7 days' AND dry_run = false GROUP BY base_model HAVING count(*) >= 10 ORDER BY round(100.0 * sum(CASE WHEN downstream_verdict='approved' THEN 1 ELSE 0 END) / NULLIF(count(CASE WHEN downstream_verdict IN ('approved','rejected','json_fail') THEN 1 END),0),2) DESC NULLS LAST LIMIT 1",
          "format": "table"
        }
      ]
    },

    {
      "id": 11,
      "title": "\ud83d\udd34 Sir Slopalot (7 days, \u226510 calls)",
      "type": "stat",
      "gridPos": { "x": 8, "y": 7, "w": 8, "h": 6 },
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "red" },
          "mappings": []
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "value",
        "colorMode": "background",
        "graphMode": "none",
        "text": { "titleSize": 16, "valueSize": 28 }
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
          "rawSql": "SELECT base_model || ' \u2014 ' || coalesce(round(100.0 * sum(CASE WHEN downstream_verdict='approved' THEN 1 ELSE 0 END) / NULLIF(count(CASE WHEN downstream_verdict IN ('approved','rejected','json_fail') THEN 1 END),0),0)::text,'?') || '% approval' AS \"Sir Slopalot\" FROM senate_telemetry WHERE timestamp > now() - interval '7 days' AND dry_run = false GROUP BY base_model HAVING count(*) >= 10 ORDER BY round(100.0 * sum(CASE WHEN downstream_verdict='approved' THEN 1 ELSE 0 END) / NULLIF(count(CASE WHEN downstream_verdict IN ('approved','rejected','json_fail') THEN 1 END),0),2) ASC NULLS LAST LIMIT 1",
          "format": "table"
        }
      ]
    },

    {
      "id": 12,
      "title": "\u26a1 Fastest Model (7 days, \u226510 calls)",
      "type": "stat",
      "gridPos": { "x": 16, "y": 7, "w": 8, "h": 6 },
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "blue" },
          "mappings": []
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "value",
        "colorMode": "background",
        "graphMode": "none",
        "text": { "titleSize": 16, "valueSize": 28 }
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
          "rawSql": "SELECT base_model || ' \u2014 ' || round(avg(latency_ms)/1000.0,1)::text || 's avg' AS \"Fastest\" FROM senate_telemetry WHERE timestamp > now() - interval '7 days' AND dry_run = false GROUP BY base_model HAVING count(*) >= 10 ORDER BY avg(latency_ms) ASC LIMIT 1",
          "format": "table"
        }
      ]
    },

    {
      "collapsed": false,
      "id": 102,
      "title": "Model Rankings",
      "type": "row",
      "gridPos": { "x": 0, "y": 13, "w": 24, "h": 1 }
    },

    {
      "id": 20,
      "title": "Model Performance — 7 Days (sorted by approval rate)",
      "type": "table",
      "gridPos": { "x": 0, "y": 14, "w": 24, "h": 14 },
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "center",
            "displayMode": "auto"
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Approval %" },
            "properties": [
              { "id": "unit", "value": "percent" },
              { "id": "min", "value": 0 },
              { "id": "max", "value": 100 },
              { "id": "custom.displayMode", "value": "color-background" },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "rgba(220,53,69,0.7)", "value": null },
                    { "color": "rgba(255,140,0,0.7)", "value": 40 },
                    { "color": "rgba(255,200,0,0.7)", "value": 60 },
                    { "color": "rgba(40,167,69,0.7)", "value": 75 }
                  ]
                }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "JSON %" },
            "properties": [
              { "id": "unit", "value": "percent" },
              { "id": "min", "value": 0 },
              { "id": "max", "value": 100 },
              { "id": "custom.displayMode", "value": "color-background" },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "rgba(220,53,69,0.7)", "value": null },
                    { "color": "rgba(255,140,0,0.7)", "value": 70 },
                    { "color": "rgba(40,167,69,0.7)", "value": 90 }
                  ]
                }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Latency (s)" },
            "properties": [
              { "id": "unit", "value": "s" },
              { "id": "custom.displayMode", "value": "color-background" },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "rgba(40,167,69,0.7)", "value": null },
                    { "color": "rgba(255,200,0,0.7)", "value": 10 },
                    { "color": "rgba(255,140,0,0.7)", "value": 30 },
                    { "color": "rgba(220,53,69,0.7)", "value": 60 }
                  ]
                }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Fidelity %" },
            "properties": [
              { "id": "unit", "value": "percent" },
              { "id": "min", "value": 0 },
              { "id": "max", "value": 100 },
              { "id": "custom.displayMode", "value": "color-background" },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "rgba(220,53,69,0.7)", "value": null },
                    { "color": "rgba(40,167,69,0.7)", "value": 95 }
                  ]
                }
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "Approval %", "desc": true }],
        "footer": { "show": false }
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
          "rawSql": "SELECT base_model AS \"Model\", count(*) AS \"Calls\", round(100.0 * sum(CASE WHEN downstream_verdict='approved' THEN 1 ELSE 0 END) / NULLIF(count(CASE WHEN downstream_verdict IN ('approved','rejected','json_fail') THEN 1 END),0),1) AS \"Approval %\", round(100.0 * sum(CASE WHEN json_parse_ok = true THEN 1 ELSE 0 END) / count(*),1) AS \"JSON %\", round(avg(latency_ms)/1000.0,1) AS \"Latency (s)\", round(avg(retries),2) AS \"Avg Retries\", round(100.0 * sum(CASE WHEN model_verified = true THEN 1 ELSE 0 END) / NULLIF(count(CASE WHEN model_verified IS NOT NULL THEN 1 END),0),1) AS \"Fidelity %\" FROM senate_telemetry WHERE timestamp > now() - interval '7 days' AND dry_run = false GROUP BY base_model HAVING count(*) >= 3 ORDER BY \"Approval %\" DESC NULLS LAST",
          "format": "table"
        }
      ]
    },

    {
      "collapsed": false,
      "id": 103,
      "title": "Role Heatmap — Approval Rate by Model \u00d7 Role",
      "type": "row",
      "gridPos": { "x": 0, "y": 28, "w": 24, "h": 1 }
    },

    {
      "id": 30,
      "title": "Approval % by Model \u00d7 Role (7 days)",
      "description": "Each cell: approval % in that role. Grey = no data. Red < 40% < Orange < 60% < Yellow < 75% < Green.",
      "type": "table",
      "gridPos": { "x": 0, "y": 29, "w": 24, "h": 12 },
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
      "fieldConfig": {
        "defaults": {
          "custom": { "align": "center", "displayMode": "auto" }
        },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": "^A[123]|^B[12]" },
            "properties": [
              { "id": "unit", "value": "percent" },
              { "id": "min", "value": 0 },
              { "id": "max", "value": 100 },
              { "id": "custom.displayMode", "value": "color-background" },
              { "id": "noValue", "value": "\u2014" },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "rgba(220,53,69,0.7)", "value": null },
                    { "color": "rgba(255,140,0,0.7)", "value": 40 },
                    { "color": "rgba(255,200,0,0.7)", "value": 60 },
                    { "color": "rgba(40,167,69,0.7)", "value": 75 }
                  ]
                }
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "Calls", "desc": true }]
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
          "rawSql": "SELECT base_model AS \"Model\", count(*) AS \"Calls\", round(100.0 * sum(CASE WHEN downstream_verdict='approved' AND role='A1_council' THEN 1 ELSE 0 END) / NULLIF(sum(CASE WHEN role='A1_council' AND downstream_verdict IN ('approved','rejected','json_fail') THEN 1 ELSE 0 END),0),0) AS \"A1 Council\", round(100.0 * sum(CASE WHEN downstream_verdict='approved' AND role='A2_drafter' THEN 1 ELSE 0 END) / NULLIF(sum(CASE WHEN role='A2_drafter' AND downstream_verdict IN ('approved','rejected','json_fail') THEN 1 ELSE 0 END),0),0) AS \"A2 Drafter\", round(100.0 * sum(CASE WHEN downstream_verdict='approved' AND role='A3_gate' THEN 1 ELSE 0 END) / NULLIF(sum(CASE WHEN role='A3_gate' AND downstream_verdict IN ('approved','rejected','json_fail') THEN 1 ELSE 0 END),0),0) AS \"A3 Gate\", round(100.0 * sum(CASE WHEN downstream_verdict='approved' AND role='B1_solver' THEN 1 ELSE 0 END) / NULLIF(sum(CASE WHEN role='B1_solver' AND downstream_verdict IN ('approved','rejected','json_fail') THEN 1 ELSE 0 END),0),0) AS \"B1 Solver\", round(100.0 * sum(CASE WHEN downstream_verdict='approved' AND role='B2_reviewer' THEN 1 ELSE 0 END) / NULLIF(sum(CASE WHEN role='B2_reviewer' AND downstream_verdict IN ('approved','rejected','json_fail') THEN 1 ELSE 0 END),0),0) AS \"B2 Reviewer\" FROM senate_telemetry WHERE timestamp > now() - interval '7 days' AND dry_run = false GROUP BY base_model HAVING count(*) >= 2 ORDER BY count(*) DESC",
          "format": "table"
        }
      ]
    },

    {
      "collapsed": false,
      "id": 104,
      "title": "Trends",
      "type": "row",
      "gridPos": { "x": 0, "y": 41, "w": 24, "h": 1 }
    },

    {
      "id": 40,
      "title": "Approval Rate Trend — 4-Hour Bins",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 42, "w": 24, "h": 10 },
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "spanNulls": false,
            "showPoints": "auto"
          }
        }
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "last"] }
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
          "rawSql": "SELECT date_trunc('hour', timestamp) + (floor(extract(epoch from timestamp - date_trunc('day',timestamp)) / 14400) * interval '4 hours') AS time, base_model AS metric, round(100.0 * sum(CASE WHEN downstream_verdict='approved' THEN 1 ELSE 0 END) / NULLIF(count(CASE WHEN downstream_verdict IN ('approved','rejected','json_fail') THEN 1 END),0),1) AS \"Approval %\" FROM senate_telemetry WHERE $__timeFilter(timestamp) AND dry_run = false GROUP BY 1, 2 HAVING count(*) >= 2 ORDER BY 1, 2",
          "format": "time_series"
        }
      ]
    },

    {
      "id": 41,
      "title": "JSON Compliance Trend — 4-Hour Bins",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 52, "w": 12, "h": 10 },
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": { "lineWidth": 2, "fillOpacity": 10, "spanNulls": false }
        }
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "last"] }
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
          "rawSql": "SELECT date_trunc('hour', timestamp) + (floor(extract(epoch from timestamp - date_trunc('day',timestamp)) / 14400) * interval '4 hours') AS time, base_model AS metric, round(100.0 * sum(CASE WHEN json_parse_ok = true THEN 1 ELSE 0 END) / count(*),1) AS \"JSON %\" FROM senate_telemetry WHERE $__timeFilter(timestamp) AND dry_run = false GROUP BY 1, 2 HAVING count(*) >= 2 ORDER BY 1, 2",
          "format": "time_series"
        }
      ]
    },

    {
      "id": 42,
      "title": "Latency Trend — 4-Hour Bins",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 52, "w": 12, "h": 10 },
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 2, "fillOpacity": 10, "spanNulls": false }
        }
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "asc" },
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "last"] }
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
          "rawSql": "SELECT date_trunc('hour', timestamp) + (floor(extract(epoch from timestamp - date_trunc('day',timestamp)) / 14400) * interval '4 hours') AS time, base_model AS metric, round(avg(latency_ms)/1000.0,2) AS \"Latency (s)\" FROM senate_telemetry WHERE $__timeFilter(timestamp) AND dry_run = false GROUP BY 1, 2 HAVING count(*) >= 2 ORDER BY 1, 2",
          "format": "time_series"
        }
      ]
    },

    {
      "collapsed": false,
      "id": 105,
      "title": "Provider Fidelity",
      "type": "row",
      "gridPos": { "x": 0, "y": 62, "w": 24, "h": 1 }
    },

    {
      "id": 50,
      "title": "Model Substitution — OpenRouter (7 days)",
      "description": "Rows where model_verified IS NOT NULL (OpenRouter only sends x-finalized-model header). Red rows = served model differed from requested model.",
      "type": "table",
      "gridPos": { "x": 0, "y": 63, "w": 14, "h": 10 },
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
      "fieldConfig": {
        "defaults": {
          "custom": { "align": "left", "displayMode": "auto" }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Verified %" },
            "properties": [
              { "id": "unit", "value": "percent" },
              { "id": "custom.displayMode", "value": "color-background" },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "rgba(220,53,69,0.7)", "value": null },
                    { "color": "rgba(255,140,0,0.7)", "value": 80 },
                    { "color": "rgba(40,167,69,0.7)", "value": 95 }
                  ]
                }
              }
            ]
          }
        ]
      },
      "options": { "showHeader": true, "sortBy": [{ "displayName": "Verified %", "desc": false }] },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
          "rawSql": "SELECT model_id AS \"Model (ID)\", model_string AS \"Requested Model\", count(*) AS \"Calls (OR)\", round(100.0 * sum(CASE WHEN model_verified = true THEN 1 ELSE 0 END) / count(*),1) AS \"Verified %\", string_agg(DISTINCT served_model, ', ' ORDER BY served_model) FILTER (WHERE model_verified = false) AS \"Substituted With\" FROM senate_telemetry WHERE timestamp > now() - interval '7 days' AND dry_run = false AND model_verified IS NOT NULL GROUP BY model_id, model_string HAVING count(*) >= 2 ORDER BY \"Verified %\" ASC",
          "format": "table"
        }
      ]
    },

    {
      "id": 51,
      "title": "Provider Fidelity Summary (7 days)",
      "type": "bargauge",
      "gridPos": { "x": 14, "y": 63, "w": 10, "h": 10 },
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 80 },
              { "color": "green", "value": 95 }
            ]
          }
        }
      },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showUnfilled": true
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
          "rawSql": "SELECT provider AS metric, round(100.0 * sum(CASE WHEN model_verified = true THEN 1 ELSE 0 END) / count(*),1) AS \"Fidelity %\" FROM senate_telemetry WHERE timestamp > now() - interval '7 days' AND dry_run = false AND model_verified IS NOT NULL GROUP BY provider HAVING count(*) >= 5 ORDER BY \"Fidelity %\" DESC",
          "format": "time_series"
        }
      ]
    },

    {
      "collapsed": false,
      "id": 106,
      "title": "Failure Analysis",
      "type": "row",
      "gridPos": { "x": 0, "y": 73, "w": 24, "h": 1 }
    },

    {
      "id": 60,
      "title": "JSON Parse Failures by Model (7 days)",
      "type": "table",
      "gridPos": { "x": 0, "y": 74, "w": 12, "h": 10 },
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
      "fieldConfig": {
        "defaults": { "custom": { "align": "center", "displayMode": "auto" } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Fail %" },
            "properties": [
              { "id": "unit", "value": "percent" },
              { "id": "custom.displayMode", "value": "color-background" },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "rgba(40,167,69,0.7)", "value": null },
                    { "color": "rgba(255,200,0,0.7)", "value": 5 },
                    { "color": "rgba(255,140,0,0.7)", "value": 15 },
                    { "color": "rgba(220,53,69,0.7)", "value": 30 }
                  ]
                }
              }
            ]
          }
        ]
      },
      "options": { "showHeader": true, "sortBy": [{ "displayName": "Fail %", "desc": true }] },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
          "rawSql": "SELECT base_model AS \"Model\", count(*) AS \"Calls\", sum(CASE WHEN json_parse_ok = false THEN 1 ELSE 0 END) AS \"Failures\", round(100.0 * sum(CASE WHEN json_parse_ok = false THEN 1 ELSE 0 END) / count(*),1) AS \"Fail %\", string_agg(DISTINCT role, ', ') FILTER (WHERE json_parse_ok = false) AS \"Failed In Roles\" FROM senate_telemetry WHERE timestamp > now() - interval '7 days' AND dry_run = false GROUP BY base_model HAVING count(*) >= 3 ORDER BY \"Fail %\" DESC NULLS LAST",
          "format": "table"
        }
      ]
    },

    {
      "id": 61,
      "title": "Retry Rates by Model (7 days)",
      "type": "bargauge",
      "gridPos": { "x": 12, "y": 74, "w": 12, "h": 10 },
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.3 },
              { "color": "orange", "value": 0.7 },
              { "color": "red", "value": 1.5 }
            ]
          }
        }
      },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showUnfilled": true
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
          "rawSql": "SELECT base_model AS metric, round(avg(retries),2) AS \"Avg Retries\" FROM senate_telemetry WHERE timestamp > now() - interval '7 days' AND dry_run = false GROUP BY base_model HAVING count(*) >= 5 ORDER BY avg(retries) DESC LIMIT 20",
          "format": "time_series"
        }
      ]
    }

  ]
}
