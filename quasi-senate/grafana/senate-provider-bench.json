{
  "__inputs": [
    {
      "name": "DS_POSTGRESQL",
      "label": "PostgreSQL",
      "description": "Postgres datasource pointing to the quasi senate_telemetry table",
      "type": "datasource",
      "pluginId": "postgres",
      "pluginName": "PostgreSQL"
    }
  ],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "10.0.0"
    },
    {
      "type": "datasource",
      "id": "postgres",
      "name": "PostgreSQL",
      "version": "1.0.0"
    }
  ],
  "annotations": {
    "list": []
  },
  "description": "Provider-level benchmarking for the QUASI Senate Loop — latency, pass rate, retry rate, and model substitution tracking across OpenRouter, Groq, HuggingFace, Fireworks, and other providers.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "title": "Cycles Today",
      "type": "stat",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 6,
        "h": 8
      },
      "datasource": {
        "type": "postgres",
        "uid": "${DS_POSTGRESQL}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "${DS_POSTGRESQL}"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT COUNT(DISTINCT cycle_id) AS value FROM senate_telemetry\nWHERE timestamp > now() - interval '24 hours' AND dry_run = false",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Pass Rate (24h)",
      "type": "gauge",
      "gridPos": {
        "x": 6,
        "y": 0,
        "w": 6,
        "h": 8
      },
      "datasource": {
        "type": "postgres",
        "uid": "${DS_POSTGRESQL}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 50
              },
              {
                "color": "green",
                "value": 80
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "${DS_POSTGRESQL}"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT ROUND(100.0 * AVG(CASE WHEN downstream_verdict IN ('approved', 'approve', 'success') THEN 1.0 ELSE 0.0 END), 1) AS value\nFROM senate_telemetry\nWHERE timestamp > now() - interval '24 hours' AND dry_run = false AND downstream_verdict IS NOT NULL",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Median Latency (24h)",
      "type": "stat",
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 6,
        "h": 8
      },
      "datasource": {
        "type": "postgres",
        "uid": "${DS_POSTGRESQL}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 30000
              },
              {
                "color": "red",
                "value": 90000
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "${DS_POSTGRESQL}"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT PERCENTILE_CONT(0.50) WITHIN GROUP (ORDER BY latency_ms) AS value\nFROM senate_telemetry\nWHERE timestamp > now() - interval '24 hours' AND dry_run = false AND error IS NULL",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Model Substitution Rate",
      "type": "stat",
      "gridPos": {
        "x": 18,
        "y": 0,
        "w": 6,
        "h": 8
      },
      "datasource": {
        "type": "postgres",
        "uid": "${DS_POSTGRESQL}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 5
              },
              {
                "color": "red",
                "value": 15
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "${DS_POSTGRESQL}"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT ROUND(100.0 * AVG(CASE WHEN model_verified = false THEN 1.0 ELSE 0.0 END), 1) AS value\nFROM senate_telemetry\nWHERE provider = 'openrouter' AND model_verified IS NOT NULL AND dry_run = false",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "Pass Rate by Provider × Base Model",
      "type": "table",
      "gridPos": {
        "x": 0,
        "y": 8,
        "w": 8,
        "h": 10
      },
      "datasource": {
        "type": "postgres",
        "uid": "${DS_POSTGRESQL}"
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {
        "sortBy": [
          {
            "displayName": "pass_rate_pct",
            "desc": true
          }
        ]
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "${DS_POSTGRESQL}"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT base_model, provider, role,\n       COUNT(*) AS n,\n       ROUND(100.0 * AVG(CASE WHEN downstream_verdict IN ('approved', 'approve', 'success') THEN 1.0 ELSE 0.0 END), 1) AS pass_rate_pct,\n       ROUND(AVG(latency_ms)) AS avg_latency_ms,\n       ROUND(100.0 * AVG(CASE WHEN json_parse_ok THEN 1.0 ELSE 0.0 END), 1) AS json_ok_pct\nFROM senate_telemetry\nWHERE dry_run = false AND downstream_verdict IS NOT NULL\nGROUP BY base_model, provider, role\nHAVING COUNT(*) >= 5\nORDER BY base_model, role, pass_rate_pct DESC",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "title": "Latency Distribution by Provider",
      "type": "timeseries",
      "gridPos": {
        "x": 8,
        "y": 8,
        "w": 8,
        "h": 10
      },
      "datasource": {
        "type": "postgres",
        "uid": "${DS_POSTGRESQL}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms"
        },
        "overrides": []
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "${DS_POSTGRESQL}"
          },
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT\n  $__timeGroupAlias(timestamp,$__interval),\n  provider,\n  AVG(latency_ms) AS avg_latency_ms\nFROM senate_telemetry\nWHERE $__timeFilter(timestamp) AND dry_run = false AND error IS NULL\nGROUP BY 1, 2\nORDER BY 1",
          "refId": "A",
          "timeColumn": "time"
        }
      ]
    },
    {
      "id": 7,
      "title": "Retry & Error Rate by Provider",
      "type": "barchart",
      "gridPos": {
        "x": 16,
        "y": 8,
        "w": 8,
        "h": 10
      },
      "datasource": {
        "type": "postgres",
        "uid": "${DS_POSTGRESQL}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent"
        },
        "overrides": []
      },
      "options": {},
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "${DS_POSTGRESQL}"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT provider,\n       COUNT(*) AS total_calls,\n       ROUND(100.0 * AVG(CASE WHEN retries > 0 THEN 1.0 ELSE 0.0 END), 1) AS retry_pct,\n       ROUND(100.0 * AVG(CASE WHEN error IS NOT NULL THEN 1.0 ELSE 0.0 END), 1) AS error_pct,\n       ROUND(100.0 * AVG(CASE WHEN json_parse_ok = false THEN 1.0 ELSE 0.0 END), 1) AS json_fail_pct\nFROM senate_telemetry\nWHERE dry_run = false\nGROUP BY provider\nORDER BY total_calls DESC",
          "refId": "A"
        }
      ]
    },
    {
      "id": 8,
      "title": "OpenRouter Model Substitution Log",
      "type": "table",
      "gridPos": {
        "x": 0,
        "y": 18,
        "w": 24,
        "h": 8
      },
      "datasource": {
        "type": "postgres",
        "uid": "${DS_POSTGRESQL}"
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {},
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "${DS_POSTGRESQL}"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT timestamp, model_id, model_string, served_model, model_verified\nFROM senate_telemetry\nWHERE provider = 'openrouter' AND served_model IS NOT NULL AND model_verified = false\nORDER BY timestamp DESC\nLIMIT 50",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "5m",
  "schemaVersion": 39,
  "tags": ["quasi", "senate", "benchmark"],
  "templating": {
    "list": []
  },
  "time": {
    "from": "now-7d",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "utc",
  "title": "QUASI Senate \u2014 Provider Benchmark",
  "uid": "quasi-senate-provider-bench",
  "version": 1,
  "weekStart": ""
}
