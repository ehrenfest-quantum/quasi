// ghz.ef
// GHZ-state preparation for three qubits.
// Circuit intent:
//   1) Prepare |000>
//   2) Apply H on q0
//   3) Entangle with CNOT q0 -> q1 and q0 -> q2
// Expected output:
//   State close to (|000> + |111>) / sqrt(2)
//   Measurement counts are concentrated on 000 and 111.

program "ghz"

qubits 3
prepare basis |000>

h q0
cnot q0 q1
cnot q0 q2

measure q0 -> c0
measure q1 -> c1
measure q2 -> c2

expect state "(|000> + |111>) / sqrt(2)"
expect counts "000,111"

