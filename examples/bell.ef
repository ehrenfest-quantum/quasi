// bell.ef
// Bell-state preparation for two qubits.
// Circuit intent:
//   1) Prepare |00>
//   2) Apply H on q0
//   3) Apply CNOT q0 -> q1
// Expected output:
//   State close to (|00> + |11>) / sqrt(2)
//   Measurement counts are concentrated on 00 and 11.

program "bell"

qubits 2
prepare basis |00>

h q0
cnot q0 q1

measure q0 -> c0
measure q1 -> c1

expect state "(|00> + |11>) / sqrt(2)"
expect counts "00,11"
